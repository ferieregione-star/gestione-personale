rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Compatibilità con la versione legacy senza Firebase Authentication.
    // ATTENZIONE: queste regole permettono lettura/scrittura alle collezioni dell'app.
    // Per produzione reale serve migrare a Firebase Authentication e regole basate su request.auth.

    match /sectors/{sectorId} { allow read, write: if true; }
    match /areas/{areaId} { allow read, write: if true; }
    match /users/{userId} { allow read, write: if true; }
    match /events/{date} { allow read, write: if true; }
    match /notifications/{noteId} { allow read, write: if true; }
    match /requests/{reqId} { allow read, write: if true; }
    match /audit/{auditId} { allow read, write: if true; }
    match /meta/{docId} { allow read, write: if true; }

    match /{document=**} { allow read, write: if false; }
  }
}
