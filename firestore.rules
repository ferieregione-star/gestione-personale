rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // App senza Firebase Authentication: l'accesso è protetto solo dal fatto
    // che l'URL dell'app non è pubblicizzato. Chiunque conosca il progetto
    // Firebase può leggere/scrivere. Per un controllo più rigido servirebbe
    // Firebase Authentication (email/password) + regole basate su request.auth.

    match /sectors/{sectorId} {
      allow read, write: if true;
    }
    match /areas/{areaId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
    match /events/{date} {
      allow read, write: if true;
    }
    match /notifications/{noteId} {
      allow read, write: if true;
    }
    match /requests/{reqId} {
      allow read, write: if true;
    }
    match /audit/{auditId} {
      allow read, write: if true;
    }
    match /meta/{docId} {
      allow read, write: if true;
    }

    // Blocca tutto il resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
